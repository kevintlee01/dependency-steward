{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowJs": false,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "jsx": "preserve",
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@dependency-steward/shared": ["packages/shared/src/index.ts"],
      "@dependency-steward/shared/*": ["packages/shared/src/*"],
      "@dependency-steward/config": ["packages/config/index.ts"],
      "@dependency-steward/db": ["packages/db/src/index.ts"],
      "@dependency-steward/db/*": ["packages/db/src/*"],
      "@dependency-steward/github": ["packages/github/src/index.ts"],
      "@dependency-steward/github/*": ["packages/github/src/*"],
      "@dependency-steward/queue": ["packages/queue/src/index.ts"],
      "@dependency-steward/queue/*": ["packages/queue/src/*"],
      "@dependency-steward/sandbox": ["packages/sandbox/src/index.ts"],
      "@dependency-steward/sandbox/*": ["packages/sandbox/src/*"],
      "@dependency-steward/dependency-intelligence": ["packages/dependency-intelligence/src/index.ts"],
      "@dependency-steward/dependency-intelligence/*": ["packages/dependency-intelligence/src/*"],
      "@dependency-steward/coverage-intelligence": ["packages/coverage-intelligence/src/index.ts"],
      "@dependency-steward/coverage-intelligence/*": ["packages/coverage-intelligence/src/*"],
      "@dependency-steward/agent-core": ["packages/agent-core/src/index.ts"],
      "@dependency-steward/agent-core/*": ["packages/agent-core/src/*"],
      "@dependency-steward/policy-engine": ["packages/policy-engine/src/index.ts"],
      "@dependency-steward/policy-engine/*": ["packages/policy-engine/src/*"],
      "@dependency-steward/prompt-kit": ["packages/prompt-kit/src/index.ts"],
      "@dependency-steward/prompt-kit/*": ["packages/prompt-kit/src/*"],
      "@dependency-steward/ui": ["packages/ui/src/index.ts"],
      "@dependency-steward/ui/*": ["packages/ui/src/*"]
    }
  }
}